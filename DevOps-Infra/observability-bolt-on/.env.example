# D6 Observability — environment template.
# Copy to `.env` (git-ignored): `cp .env.example .env`
# docker compose automatically reads `.env` from this directory.

# ---- Application ----------------------------------------------------------
APP_ENV=docker
LOG_LEVEL=INFO

# ---- Grafana --------------------------------------------------------------
# DEMO default is admin/admin. For ANY shared/prod use, set a strong password
# here (or in the environment) and run with the prod overlay (see README):
#   docker compose -f docker-compose.yml -f compose.prod.yml up -d
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Anonymous read-only viewing — convenient for the local demo, disabled in prod.
GF_AUTH_ANONYMOUS_ENABLED=true

# ---- Tracing (optional; enabled by compose.tracing.yml) -------------------
OTEL_ENABLED=false
OTEL_SERVICE_NAME=d6-sample
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
