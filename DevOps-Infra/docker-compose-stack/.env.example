# D2 Docker Compose stack — environment template.
# Copy to `.env` (git-ignored): `cp .env.example .env`
# docker compose automatically reads `.env` from this directory.
#
# These are DEMO defaults. For any shared/prod use, set a strong POSTGRES_PASSWORD
# and a non-empty API_KEY, and run with the prod overlay (see README):
#   docker compose -f docker-compose.yml -f compose.prod.yml up -d

# ---- Database -------------------------------------------------------------
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
POSTGRES_DB=appdb

# ---- API ------------------------------------------------------------------
# DATABASE_URL is composed from the POSTGRES_* values in docker-compose.yml.
# Override it here only when pointing the API at an external database.
# DATABASE_URL=postgresql://appuser:apppass@database:5432/appdb

# Leave API_KEY empty to disable auth (demo default). Set a value to require an
# `X-API-Key: <value>` header on all routes except /health and /metrics.
API_KEY=
LOG_LEVEL=INFO

# ---- Worker ---------------------------------------------------------------
WORKER_ID=worker-1
