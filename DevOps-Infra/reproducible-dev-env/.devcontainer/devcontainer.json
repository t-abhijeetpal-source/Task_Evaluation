{
  "name": "D5 Reproducible Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/base:debian-12",
  "features": {
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12.8" },
    "ghcr.io/devcontainers/features/node:1": { "version": "22.12.0" }
  },
  "containerEnv": {
    "APP_ENV": "dev",
    "PYTHONDONTWRITEBYTECODE": "1"
  },
  "postCreateCommand": "python -m venv .venv && ./.venv/bin/python -m pip install -q -r requirements-dev.txt",
  "postStartCommand": "./.venv/bin/python -m pytest -q",
  "forwardPorts": [8000]
}
