# EXAMPLE ONLY — do not apply this file with real values committed to git.
# Rename to secret.yaml (git-ignored) and fill in for a quick local test, OR —
# preferred for any shared/prod cluster — manage secrets out-of-band:
#
#   * External Secrets Operator  — sync from AWS Secrets Manager / Vault / GCP SM
#   * Sealed Secrets (Bitnami)   — commit an encrypted SealedSecret, the
#                                  controller decrypts it in-cluster
#   * SOPS + age                 — encrypt the YAML at rest in the repo
#
# Consume in the Deployment exactly like the ConfigMap, e.g.:
#   envFrom:
#     - configMapRef: { name: d4-config }
#     - secretRef:    { name: d4-secret }
apiVersion: v1
kind: Secret
metadata:
  name: d4-secret
  namespace: d4-sample
  labels:
    app.kubernetes.io/name: d4-sample
    app.kubernetes.io/component: config
type: Opaque
stringData:
  # Placeholders — replace at deploy time; never commit real credentials.
  API_TOKEN: "replace-me"
  DATABASE_URL: "postgresql://user:replace-me@db.internal:5432/d4"
