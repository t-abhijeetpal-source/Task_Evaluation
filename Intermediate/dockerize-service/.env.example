# Example environment configuration for the dockerized currency service.
# Copy to .env (or pass with `docker run -e ...`). All values shown are safe defaults.

# Deployment environment: development | production
# In production, CORS fails closed unless CORS_ORIGINS is set.
ENV=development

# Comma-separated allow-list of CORS origins.
# Unset -> localhost dev origins in development, deny-all in production.
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Per-IP request budget for /convert over a 60s window.
RATE_LIMIT_PER_MINUTE=60

# Maximum accepted request body size, in bytes.
MAX_BODY_BYTES=1024

# Port uvicorn binds inside the container.
PORT=8000

# Build identifier surfaced by /health and /ready (wire to the CI git SHA).
BUILD_ID=dev
